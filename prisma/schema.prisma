generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UserAccount {
  id         String   @id
  fullName   String
  email      String   @unique
  role       String   // STUDENT | COORDINATOR | ADMINISTRATOR
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mobilityRecords        MobilityRecord[]    @relation("StudentMobilityRecords")
  coordinatorAssignments MobilityRecord[]    @relation("CoordinatorMobilityRecords")
  documentSubmissions    DocumentSubmission[]
  submissionEvents       SubmissionEvent[]
  exceptionRequests      ExceptionRequest[]
  exceptionEvents        ExceptionEvent[]
  auditRecords           AuditRecord[]
  socialSupportProfile   SocialSupportProfile?
  sentConnections        SocialConnection[]    @relation("ConnectionRequester")
  receivedConnections    SocialConnection[]    @relation("ConnectionRecipient")
  blockedConnections     SocialConnection[]    @relation("ConnectionBlockedBy")
  sentMessages           Message[]             @relation("MessageSender")
  authoredSocialContent  SocialContent[]       @relation("SocialContentAuthor")
  socialFavorites        SocialFavorite[]
  moderationReports      ModerationReport[]    @relation("ModerationReporter")
  moderatedCases         ModerationCase[]      @relation("ModerationModerator")
}

model Institution {
  id         String   @id
  name       String
  createdAt  DateTime @default(now())

  mobilityRecords MobilityRecord[]
  procedures      ProcedureDefinition[]
}

model MobilityRecord {
  id              String   @id
  studentId       String
  coordinatorId   String
  institutionId   String
  state           String   // DRAFT | SUBMITTED | IN_REVIEW | APPROVED | ACTIVE | COMPLETED | CLOSED | TERMINATED
  destinationCity String
  mobilityType    String
  mobilityPhase   String   @default("DURING_MOBILITY") // PRE_DEPARTURE | DURING_MOBILITY | END_OF_MOBILITY
  mobilityStart   DateTime
  mobilityEnd     DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student      UserAccount               @relation("StudentMobilityRecords", fields: [studentId], references: [id])
  coordinator  UserAccount               @relation("CoordinatorMobilityRecords", fields: [coordinatorId], references: [id])
  institution  Institution               @relation(fields: [institutionId], references: [id])
  submissions  DocumentSubmission[]
  deadlines    Deadline[]
  exceptions   ExceptionRequest[]
  socialProfiles SocialSupportProfile[]
}

model ProcedureDefinition {
  id            String   @id
  institutionId String
  title         String
  version       Int
  state         String   // DRAFT | PUBLISHED | LOCKED | SUPERSEDED
  phase         String   @default("DURING_MOBILITY") // PRE_DEPARTURE | DURING_MOBILITY | END_OF_MOBILITY
  createdAt     DateTime @default(now())

  institution        Institution                 @relation(fields: [institutionId], references: [id])
  submissions        DocumentSubmission[]
  applicabilityRules ProcedureApplicabilityRule[]
  deadlines          Deadline[]
}

model ProcedureApplicabilityRule {
  id                    String @id
  procedureDefinitionId String
  destinationCity       String?
  mobilityType          String?
  lifecyclePhase        String?
  isActive              Boolean @default(true)

  procedureDefinition ProcedureDefinition @relation(fields: [procedureDefinitionId], references: [id])

  @@index([procedureDefinitionId])
}

model DocumentSubmission {
  id                    String    @id
  mobilityRecordId      String
  procedureDefinitionId String
  studentId             String
  state                 String    // DRAFT | SUBMITTED | IN_REVIEW | APPROVED | REJECTED | REOPENED | RESUBMITTED | ARCHIVED
  rejectionRationale    String?
  reopeningRationale    String?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  mobilityRecord      MobilityRecord      @relation(fields: [mobilityRecordId], references: [id])
  procedureDefinition ProcedureDefinition @relation(fields: [procedureDefinitionId], references: [id])
  student             UserAccount         @relation(fields: [studentId], references: [id])
  events              SubmissionEvent[]

  @@index([studentId])
  @@index([mobilityRecordId])
}

model SubmissionEvent {
  id           String   @id
  submissionId String
  actorId      String
  fromState    String?
  toState      String
  rationale    String?
  createdAt    DateTime @default(now())

  submission DocumentSubmission @relation(fields: [submissionId], references: [id])
  actor      UserAccount        @relation(fields: [actorId], references: [id])

  @@index([submissionId])
}

model Deadline {
  id                    String   @id
  mobilityRecordId      String
  procedureDefinitionId String?
  title                 String
  dueAt                 DateTime
  overrideDueAt         DateTime?
  state                 String   // UPCOMING | OVERRIDDEN | OVERDUE | FULFILLED
  obligationType        String   // SUBMISSION | REVIEW | RESUBMISSION
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  mobilityRecord      MobilityRecord      @relation(fields: [mobilityRecordId], references: [id])
  procedureDefinition ProcedureDefinition? @relation(fields: [procedureDefinitionId], references: [id])

  @@index([mobilityRecordId])
  @@index([dueAt])
}

model ExceptionRequest {
  id               String   @id
  mobilityRecordId String
  studentId        String
  scopeType        String   // DEADLINE | DOCUMENT | PROCEDURE
  scopeRefId       String?
  reason           String
  state            String   // SUBMITTED | IN_REVIEW | APPROVED | REJECTED | APPLIED | CLOSED
  decisionRationale String?
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mobilityRecord MobilityRecord  @relation(fields: [mobilityRecordId], references: [id])
  student        UserAccount     @relation(fields: [studentId], references: [id])
  events         ExceptionEvent[]

  @@index([mobilityRecordId])
  @@index([studentId])
  @@index([state])
}

model ExceptionEvent {
  id          String   @id
  exceptionId String
  actorId     String
  fromState   String?
  toState     String
  rationale   String?
  createdAt   DateTime @default(now())

  exception ExceptionRequest @relation(fields: [exceptionId], references: [id])
  actor     UserAccount      @relation(fields: [actorId], references: [id])

  @@index([exceptionId])
}

model AuditRecord {
  id           String   @id
  actorId      String
  actionType   String   // SUBMISSION_DRAFT_CREATED | SUBMISSION_SUBMITTED | ...
  targetType   String
  targetId     String
  priorState   String?
  newState     String?
  outcome      String
  metadataJson String?
  createdAt    DateTime @default(now())

  actor UserAccount @relation(fields: [actorId], references: [id])

  @@index([targetId])
}

model SocialSupportProfile {
  id                   String   @id
  userId               String   @unique
  mobilityRecordId     String
  headline             String?
  bio                  String?
  languages            String?
  interests            String?
  profileState         String   // unavailable | profile_active_private | discoverable | contactable | consent_revoked_or_restricted
  discoverable         Boolean  @default(false)
  contactable          Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 UserAccount               @relation(fields: [userId], references: [id])
  mobilityRecord       MobilityRecord            @relation(fields: [mobilityRecordId], references: [id])
  visibilitySettings   SocialVisibilitySettings?
  consentSettings      SocialConsentSettings?
  requestedConnections SocialConnection[]        @relation("ProfileRequestedConnections")
  receivedConnections  SocialConnection[]        @relation("ProfileReceivedConnections")
  authoredContent      SocialContent[]

  @@index([discoverable])
  @@index([contactable])
}

model SocialVisibilitySettings {
  id                         String  @id
  profileId                  String  @unique
  showHeadline               Boolean @default(true)
  showBio                    Boolean @default(false)
  showLanguages              Boolean @default(true)
  showInterests              Boolean @default(true)
  showDestination            Boolean @default(true)
  showHostInstitution        Boolean @default(true)
  showCity                   Boolean @default(true)
  showMobilityPeriod         Boolean @default(true)
  showMobilityStage          Boolean @default(true)
  directContactExposed       Boolean @default(false)

  profile                    SocialSupportProfile @relation(fields: [profileId], references: [id])
}

model SocialConsentSettings {
  id                     String    @id
  profileId              String    @unique
  discoverabilityConsent Boolean   @default(false)
  contactabilityConsent  Boolean   @default(false)
  consentRevokedAt       DateTime?

  profile                SocialSupportProfile @relation(fields: [profileId], references: [id])
}

model SocialConnection {
  id                  String   @id
  requesterProfileId  String
  recipientProfileId  String
  requesterUserId     String
  recipientUserId     String
  state               String   // pending | accepted | rejected | cancelled | expired | blocked | closed
  initiatedAt         DateTime @default(now())
  respondedAt         DateTime?
  closedAt            DateTime?
  blockedByUserId     String?

  requesterProfile    SocialSupportProfile @relation("ProfileRequestedConnections", fields: [requesterProfileId], references: [id])
  recipientProfile    SocialSupportProfile @relation("ProfileReceivedConnections", fields: [recipientProfileId], references: [id])
  requesterUser       UserAccount          @relation("ConnectionRequester", fields: [requesterUserId], references: [id])
  recipientUser       UserAccount          @relation("ConnectionRecipient", fields: [recipientUserId], references: [id])
  blockedBy           UserAccount?         @relation("ConnectionBlockedBy", fields: [blockedByUserId], references: [id])
  thread              MessageThread?

  @@index([requesterUserId])
  @@index([recipientUserId])
  @@index([state])
}

model MessageThread {
  id               String   @id
  connectionId     String   @unique
  permissionState  String   // not_permitted | permitted | blocked | expired_or_closed_retained
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  connection       SocialConnection @relation(fields: [connectionId], references: [id])
  messages         Message[]
}

model Message {
  id           String   @id
  threadId     String
  senderUserId String
  messageText  String
  sentAt       DateTime @default(now())

  thread       MessageThread @relation(fields: [threadId], references: [id])
  sender       UserAccount   @relation("MessageSender", fields: [senderUserId], references: [id])

  @@index([threadId, sentAt])
}

model PlaceContext {
  id           String   @id
  label        String
  city         String
  country      String
  category     String   // university_area | student_housing_zone | transport_hub | civic_office | daily_living_area
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())

  socialContent SocialContent[]

  @@index([city])
}

model SocialContent {
  id                 String   @id
  authorId           String
  authorProfileId    String
  kind               String   // recommendation | tip | review | opinion
  title              String
  body               String
  rating             Int?
  destinationCity    String
  topicCategory      String   // accommodation | transport | bureaucracy | academics | daily_living
  placeContextId     String?
  state              String   // draft_or_editing | published_visible | updated_visible | author_deleted | hidden_or_restricted | removed
  moderationState    String   @default("VISIBLE") // VISIBLE | THRESHOLD_HIDDEN | HIDDEN | RESTRICTED | REMOVED
  reportCount        Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  author             UserAccount          @relation("SocialContentAuthor", fields: [authorId], references: [id])
  authorProfile      SocialSupportProfile @relation(fields: [authorProfileId], references: [id])
  placeContext       PlaceContext?        @relation(fields: [placeContextId], references: [id])
  favorites          SocialFavorite[]
  reports            ModerationReport[]   @relation("ContentReports")
  moderationCases    ModerationCase[]     @relation("ContentModerationCases")

  @@index([authorId])
  @@index([destinationCity])
  @@index([kind])
  @@index([state, moderationState])
}

model SocialFavorite {
  id              String   @id
  userId          String
  socialContentId String
  createdAt       DateTime @default(now())

  user            UserAccount   @relation(fields: [userId], references: [id])
  socialContent   SocialContent @relation(fields: [socialContentId], references: [id])

  @@unique([userId, socialContentId])
  @@index([userId, createdAt])
}

model ModerationReport {
  id               String   @id
  reporterId       String
  targetType       String   // recommendation | tip | review | opinion | message | social_profile | social_interaction
  targetContentId  String?
  reportReason     String
  reportDetails    String?
  state            String   @default("reported") // reported | in_review | resolved
  reportedAt       DateTime @default(now())
  reviewedAt       DateTime?

  reporter         UserAccount     @relation("ModerationReporter", fields: [reporterId], references: [id])
  targetContent    SocialContent?  @relation("ContentReports", fields: [targetContentId], references: [id])
  moderationCaseId String?
  moderationCase   ModerationCase? @relation(fields: [moderationCaseId], references: [id])

  @@index([targetType, targetContentId])
  @@index([state, reportedAt])
}

model ModerationCase {
  id                   String   @id
  targetType           String   // recommendation | tip | review | opinion | message | social_profile | social_interaction
  targetContentId      String?
  caseState            String   // reported | threshold_hidden_pending_review | in_review | resolved_hidden | resolved_removed | resolved_restricted | cleared
  thresholdTriggered   Boolean  @default(false)
  outcomeSummary       String?
  moderationAction     String?  // hide | remove | restrict | maintain_visible | clear
  moderatorId          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  resolvedAt           DateTime?

  reports              ModerationReport[]
  targetContent        SocialContent? @relation("ContentModerationCases", fields: [targetContentId], references: [id])
  moderator            UserAccount?   @relation("ModerationModerator", fields: [moderatorId], references: [id])

  @@index([caseState, updatedAt])
  @@index([targetType, targetContentId])
}
