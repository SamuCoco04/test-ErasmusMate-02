generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UserAccount {
  id         String   @id
  fullName   String
  email      String   @unique
  role       String   // STUDENT | COORDINATOR | ADMINISTRATOR
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mobilityRecords        MobilityRecord[]    @relation("StudentMobilityRecords")
  coordinatorAssignments MobilityRecord[]    @relation("CoordinatorMobilityRecords")
  documentSubmissions    DocumentSubmission[]
  submissionEvents       SubmissionEvent[]
  exceptionRequests      ExceptionRequest[]
  exceptionEvents        ExceptionEvent[]
  auditRecords           AuditRecord[]
}

model Institution {
  id         String   @id
  name       String
  createdAt  DateTime @default(now())

  mobilityRecords MobilityRecord[]
  procedures      ProcedureDefinition[]
}

model MobilityRecord {
  id              String   @id
  studentId       String
  coordinatorId   String
  institutionId   String
  state           String   // DRAFT | SUBMITTED | IN_REVIEW | APPROVED | ACTIVE | COMPLETED | CLOSED | TERMINATED
  destinationCity String
  mobilityType    String
  mobilityPhase   String   @default("DURING_MOBILITY") // PRE_DEPARTURE | DURING_MOBILITY | END_OF_MOBILITY
  mobilityStart   DateTime
  mobilityEnd     DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student      UserAccount               @relation("StudentMobilityRecords", fields: [studentId], references: [id])
  coordinator  UserAccount               @relation("CoordinatorMobilityRecords", fields: [coordinatorId], references: [id])
  institution  Institution               @relation(fields: [institutionId], references: [id])
  submissions  DocumentSubmission[]
  deadlines    Deadline[]
  exceptions   ExceptionRequest[]
}

model ProcedureDefinition {
  id            String   @id
  institutionId String
  title         String
  version       Int
  state         String   // DRAFT | PUBLISHED | LOCKED | SUPERSEDED
  phase         String   @default("DURING_MOBILITY") // PRE_DEPARTURE | DURING_MOBILITY | END_OF_MOBILITY
  createdAt     DateTime @default(now())

  institution        Institution                 @relation(fields: [institutionId], references: [id])
  submissions        DocumentSubmission[]
  applicabilityRules ProcedureApplicabilityRule[]
  deadlines          Deadline[]
}

model ProcedureApplicabilityRule {
  id                    String @id
  procedureDefinitionId String
  destinationCity       String?
  mobilityType          String?
  lifecyclePhase        String?
  isActive              Boolean @default(true)

  procedureDefinition ProcedureDefinition @relation(fields: [procedureDefinitionId], references: [id])

  @@index([procedureDefinitionId])
}

model DocumentSubmission {
  id                    String    @id
  mobilityRecordId      String
  procedureDefinitionId String
  studentId             String
  state                 String    // DRAFT | SUBMITTED | IN_REVIEW | APPROVED | REJECTED | REOPENED | RESUBMITTED | ARCHIVED
  rejectionRationale    String?
  reopeningRationale    String?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  mobilityRecord      MobilityRecord      @relation(fields: [mobilityRecordId], references: [id])
  procedureDefinition ProcedureDefinition @relation(fields: [procedureDefinitionId], references: [id])
  student             UserAccount         @relation(fields: [studentId], references: [id])
  events              SubmissionEvent[]

  @@index([studentId])
  @@index([mobilityRecordId])
}

model SubmissionEvent {
  id           String   @id
  submissionId String
  actorId      String
  fromState    String?
  toState      String
  rationale    String?
  createdAt    DateTime @default(now())

  submission DocumentSubmission @relation(fields: [submissionId], references: [id])
  actor      UserAccount        @relation(fields: [actorId], references: [id])

  @@index([submissionId])
}

model Deadline {
  id                    String   @id
  mobilityRecordId      String
  procedureDefinitionId String?
  title                 String
  dueAt                 DateTime
  overrideDueAt         DateTime?
  state                 String   // UPCOMING | OVERRIDDEN | OVERDUE | FULFILLED
  obligationType        String   // SUBMISSION | REVIEW | RESUBMISSION
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  mobilityRecord      MobilityRecord      @relation(fields: [mobilityRecordId], references: [id])
  procedureDefinition ProcedureDefinition? @relation(fields: [procedureDefinitionId], references: [id])

  @@index([mobilityRecordId])
  @@index([dueAt])
}

model ExceptionRequest {
  id               String   @id
  mobilityRecordId String
  studentId        String
  scopeType        String   // DEADLINE | DOCUMENT | PROCEDURE
  scopeRefId       String?
  reason           String
  state            String   // SUBMITTED | IN_REVIEW | APPROVED | REJECTED | APPLIED | CLOSED
  decisionRationale String?
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mobilityRecord MobilityRecord  @relation(fields: [mobilityRecordId], references: [id])
  student        UserAccount     @relation(fields: [studentId], references: [id])
  events         ExceptionEvent[]

  @@index([mobilityRecordId])
  @@index([studentId])
  @@index([state])
}

model ExceptionEvent {
  id          String   @id
  exceptionId String
  actorId     String
  fromState   String?
  toState     String
  rationale   String?
  createdAt   DateTime @default(now())

  exception ExceptionRequest @relation(fields: [exceptionId], references: [id])
  actor     UserAccount      @relation(fields: [actorId], references: [id])

  @@index([exceptionId])
}

model AuditRecord {
  id           String   @id
  actorId      String
  actionType   String   // SUBMISSION_DRAFT_CREATED | SUBMISSION_SUBMITTED | ...
  targetType   String
  targetId     String
  priorState   String?
  newState     String?
  outcome      String
  metadataJson String?
  createdAt    DateTime @default(now())

  actor UserAccount @relation(fields: [actorId], references: [id])

  @@index([targetId])
}
